/* JinJI 极简资产管理小程序全局样式 */
page {
  background: #F7F4EE;
  color: #222;
  font-family: 'SF Pro', 'Helvetica Neue', Arial, sans-serif;
}
.container {
  padding: 24rpx 24rpx 60rpx;
}
.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.06);
}
.section-title {
  font-size: 28rpx;
  color: #222222;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.text-muted {
  color: #7D7D7D;
}
.button-primary {
  background: #A44A3F;
  color: #FFFFFF;
}
.button-secondary {
  border: 1rpx solid #D8D3C7;
  color: #222222;
  background: #F7F4EE;
}
.input-field {
  margin-top: 20rpx;
}
.input-label {
  color: #5B5B5B;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}
.input-box {
  background: #F5F2E9;
  border-radius: 18rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #222;
}
.tag {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 18rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  background: #F5F2E9;
  color: #4C4C4C;
}
