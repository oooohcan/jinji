.input-box textarea {
  width: 100%;
}

.analysis-result {
  margin-top: 20rpx;
}

.summary-text {
  display: block;
  line-height: 40rpx;
  color: #333333;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.tags-group {
  display: flex;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.tag-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tag-label {
  font-size: 22rpx;
  color: #999999;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #F5F2E9;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #666666;
}

.tag.direction-long {
  background: #E8F5E9;
  color: #2D6A4F;
}

.tag.direction-short {
  background: #FFEBEE;
  color: #A44A3F;
}

.tag.direction-neutral {
  background: #F5F2E9;
  color: #999999;
}

.keywords-group {
  margin-top: 24rpx;
}

.keywords-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.keyword-item {
  padding: 8rpx 14rpx;
  background: #F0EDE5;
  border-radius: 14rpx;
  font-size: 22rpx;
  color: #666666;
}

.warning-text {
  display: block;
  margin-top: 16rpx;
  line-height: 40rpx;
  color: #A44A3F;
  font-size: 26rpx;
}

.insight-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.insight-item:last-child {
  border-bottom: none;
}

.insight-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.insight-date {
  font-size: 22rpx;
  color: #CCCCCC;
}

.insight-direction {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #F5F2E9;
  color: #999999;
}

.insight-direction.direction-long {
  background: #E8F5E9;
  color: #2D6A4F;
}

.insight-direction.direction-short {
  background: #FFEBEE;
  color: #A44A3F;
}

.insight-summary {
  display: block;
  line-height: 36rpx;
  color: #555555;
  font-size: 24rpx;
}
