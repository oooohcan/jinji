.account-scroll {
  display: flex;
  flex-direction: row;
  width: 100%;
  overflow-x: scroll;
}
.row {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.card small {
  color: #7D7D7D;
}
.module-card {
  padding: 28rpx;
  border-radius: 32rpx;
}
.module-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 18rpx;
}
.module-link {
  color: #A44A3F;
  font-size: 24rpx;
}
.dashboard-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
}
.stat-card {
  background: #FFF8F3;
  border-radius: 28rpx;
  padding: 24rpx;
  flex: 1 1 48%;
  min-width: 220rpx;
}
.stat-label {
  color: #7D7D7D;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}
.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #222222;
}
.stat-value.small {
  font-size: 24rpx;
  font-weight: 400;
}
.warning-card {
  background: #FDF2F0;
  border-radius: 24rpx;
  padding: 22rpx;
  margin-top: 22rpx;
}
.warning-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #A44A3F;
  margin-bottom: 10rpx;
}
.warning-text {
  color: #5B5B5B;
  line-height: 36rpx;
}
.asset-preview {
  margin-top: 24rpx;
}
.section-subtitle {
  margin-bottom: 16rpx;
  color: #4F4F4F;
  font-size: 26rpx;
}
.asset-row {
  flex-wrap: wrap;
  gap: 16rpx;
}
.asset-card {
  display: block;
  flex: 1 1 46%;
  min-width: 260rpx;
  background: #F7F2EA;
  border-radius: 24rpx;
  padding: 20rpx;
  text-decoration: none;
}
.asset-name {
  font-size: 28rpx;
  font-weight: 600;
}
.asset-meta,
.asset-summary {
  font-size: 24rpx;
  color: #6F6F6F;
  margin-top: 10rpx;
}
