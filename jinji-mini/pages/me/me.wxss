.me-header {
  background: linear-gradient(135deg, #A44A3F 0%, #8B3D34 100%);
  padding: 40rpx 24rpx;
  border-radius: 0 0 32rpx 32rpx;
  margin: -24rpx -24rpx 24rpx -24rpx;
}

.avatar-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
  text-decoration: none;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-label {
  color: #222222;
  font-size: 26rpx;
}

.menu-arrow {
  color: #CCCCCC;
  font-size: 26rpx;
}

.stat-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-box {
  flex: 1;
  background: #F5F2E9;
  border-radius: 24rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #A44A3F;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 26rpx;
  color: #222222;
}

.setting-value {
  color: #999999;
  font-size: 24rpx;
}

.about-text {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 12rpx 0;
}

.about-text text {
  font-size: 24rpx;
  color: #999999;
  line-height: 36rpx;
}
